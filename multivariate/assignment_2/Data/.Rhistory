KidneyFailure <- read.table("KindneyFailure.txt", header = FALSE)
names(KidneyFailure) <- c("days","treat_dur","weight","id")
#convert to factors
KidneyFailure$treat_dur <- factor(KidneyFailure$treat_dur, levels=c(1,2), labels=c("Short","Long"))
KidneyFailure$weight   <- factor(KidneyFailure$weight,   levels=c(1,2,3), labels=c("Light","Medium","Heavy"))
str(KidneyFailure);
table(KidneyFailure$treat_dur, KidneyFailure$weight) #evenly balanced
#Basic EDA
boxplot(days ~ weight, data = KidneyFailure)
boxplot(days ~ treat_dur, data = KidneyFailure)
aggregate(days ~ treat_dur + weight, data = KidneyFailure, mean)
reat_dur, KidneyFailure$weight) #evenly balanced
#Basic EDA
boxplot(days ~ weight, data = KidneyFailure)
boxplot(days ~ treat_dur, data = KidneyFailure)
aggregate(days ~ treat_dur + weight, data = KidneyFailure, mean)
boxplot(days ~ treat_dur, data = KidneyFailure)
aggregate(days ~ treat_dur + weight, data = KidneyFailure, mean)
# cell means model
cellmod <- lm(days ~ treat_dur:weight - 1, data = KidneyFailure)   #removesintercept
summary(cellmod)
# get cell means
aggregate(days ~ treat_dur + weight, data = KidneyFailure, FUN = mean)
#main effects + interaction (Y=μ+αduration +βweight +(αβ)+ε)
aov_mod <- aov(days ~ treat_dur * weight, data = KidneyFailure)
summary(aov_mod)
#H0:(αβ)=0f 𝑝=0.162>0.05 Fail to reject 𝐻0v➡ No statistical evidence of interaction
#weight:F = 13.121 p = 2.27e-05 -->𝜇1=𝜇2=𝜇3 rejected
Anova(aov_mod, type="II")
#each main effect tested after adjusting for the other main effect and order is insignificant
# residuals
resid_std <- rstandard(aov_mod)
resid_stud <- rstudent(aov_mod)
fitted_vals <- fitted(aov_mod)
# plots
par(mfrow=c(2,2))
plot(fitted_vals, resid_std, main="Residuals vs Fitted", xlab="Fitted", ylab="Std Resid")
abline(h=0, col="red")
qqnorm(resid_std); qqline(resid_std)
plot(hatvalues(aov_mod), resid_std, main="Leverage vs Residuals", xlab="Leverage", ylab="Std Resid")
plot(cooks.distance(aov_mod), type="h", main="Cook's distances")
par(mfrow=c(1,1))
#1. Normality
shapiro.test(resid_std)
#p-value<0.05 showing statistical evidence of non-normality in residuals
ks.test(resid_std, "pnorm", mean=mean(resid_std), sd=sd(resid_std))
#p-value>0.05 hence null hypothesis is not rejected meaning normality holds
#difference in results because Shapiro–Wilk is more powerful for detecting skewness and departures at tails
#KS test is relatively insensitive for departure at the tails and to larger sample sizes (n>50)
#however, we had to estimate the mean and SD from the data reducing its validity
#2. Constant Variance
#within-cell variances
library(dplyr)
cell_vars <- KidneyFailure %>%
group_by(treat_dur, weight) %>%
summarize(n = n(), mean = mean(days), var = var(days))
cell_vars
# Hartley Fmax
Fmax <- max(cell_vars$var, na.rm=TRUE)/min(cell_vars$var, na.rm=TRUE)
Fmax
#largest variance is ~18 times the smallest variance
# Brown-Forsythe
leveneTest(days ~ treat_dur*weight, data = KidneyFailure, center=median)  # from car
#p < 0.01 = variance is not homogeneous across combined groups
lambda_opt
